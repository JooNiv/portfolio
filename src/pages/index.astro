---
import '../index.css';

import { getCollection, getEntry } from 'astro:content';

import { Hero } from '../components/sections/hero.jsx';
import Layout from '../layouts/Layout.astro';

const folderContent = await getCollection('folderContent');

const heroContent = await getEntry('heroContent', 'hero');

const sortedFolderContent = folderContent.sort((a, b) => a.data.index - b.data.index);

---


<Layout>
	<Hero folderContent={sortedFolderContent} heroContent={heroContent} client:idle/>
</Layout>
