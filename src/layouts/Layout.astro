---
import { flex } from "../../styled-system/patterns";

import { Header } from "../components/layout/header";
import { Footer } from "../components/layout/footer";
import { Modal } from "../components/layout/modal";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/JN.svg" />
		<link rel="icon" href="/JN.ico" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Righteous&family=VT323&display=swap"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Righteous&family=VT323&display=swap"
				rel="stylesheet"
			/>
		</noscript>
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Joonas Nivala's personal portfolio website"
		/>
		<title>Joonas Nivala</title>
		<script is:inline>
			const theme =
				localStorage.getItem("theme") ||
				(window.matchMedia("(prefers-color-scheme: dark)").matches
					? "dark"
					: "light");
			document.documentElement.setAttribute("data-theme", theme);
		</script>
	</head>
	<body
		class={flex({
			direction: "column",
			align: "center",
			bg: "bg",
			minHeight: "100vh",
			width: "full",
		})}
	>
		<main
			class={flex({
				direction: "column",
				bg: "transparent",
				align: "center",
				justify: "space-between",
				maxWidth: "1000px",
				minHeight: "100vh",
				height: "full",
				width: "full",
				paddingX: "2rem",
			})}
		>
			<Header client:only="solidjs" />
			<div class={flex({
				direction: "column",
				flex: "1",
				width: "full",
			})}>
				<slot />
			</div>
			<Footer client:only="solidjs" />
		</main>
		<Modal client:only="solidjs" />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	body::before {
		content: "";
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.06'/%3E%3C/svg%3E");
	}
	[data-theme="light"] body::before {
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.18'/%3E%3C/svg%3E");
	}
</style>
